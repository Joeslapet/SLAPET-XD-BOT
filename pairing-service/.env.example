# Port configuration
PORT=3000
HOST=0.0.0.0

# Public URL (for Render)
PUBLIC_URL=https://xxxd-bot-pairing.onrender.com

# Security
API_KEY=your-secret-api-key-change-this

# Session configuration
SESSION_TTL_MINUTES=60
SESSION_CLEANUP_MINUTES=10

# Logging
LOG_LEVEL=info

# CORS settings
CORS_ORIGIN=*

# Rate limiting
PAIRING_RATE_LIMIT_MAX=5
PAIRING_RATE_LIMIT_WINDOW_MINUTES=5

# Bot connection (optional)
BOT_API_URL=http://localhost:3001
BOT_API_KEY=your-bot-api-key
