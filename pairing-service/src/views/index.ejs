<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Bot Pairing</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #25D366;
            --dark: #075E54;
            --danger: #E74C3C;
            --text: #111B21;
            --light: #F0F2F5;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, var(--dark), var(--primary));
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            width: 100%;
            max-width: 400px;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, var(--dark), var(--primary));
            color: white;
            padding: 30px 20px;
            text-align: center;
        }

        .header h1 {
            font-size: 24px;
            margin-bottom: 8px;
        }

        .content {
            padding: 30px 20px;
        }

        .step {
            display: none;
        }

        .step.active {
            display: block;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        h2 {
            color: var(--text);
            font-size: 18px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: var(--text);
            font-weight: 500;
            margin-bottom: 8px;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--light);
            border-radius: 8px;
            font-size: 16px;
            transition: border 0.3s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: #1FB856;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(37,211,102,0.3);
        }

        .btn-secondary {
            background: var(--light);
            color: var(--text);
            margin-top: 10px;
        }

        .btn-secondary:hover {
            background: #E5E5EA;
        }

        .code-display {
            background: var(--light);
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            margin: 20px 0;
        }

        .code-label {
            color: #65676B;
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .code-value {
            font-family: 'Courier New', monospace;
            font-size: 36px;
            font-weight: 700;
            letter-spacing: 4px;
            color: var(--primary);
            margin-bottom: 15px;
        }

        .copy-btn {
            background: white;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 10px 15px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .copy-btn:hover {
            background: var(--primary);
            color: white;
        }

        .status {
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            margin: 15px 0;
            font-weight: 500;
        }

        .status-pending {
            background: #FFF3E0;
            color: #E65100;
        }

        .status-connected {
            background: #E8F5E9;
            color: #1B5E20;
        }

        .status-error {
            background: #FFEBEE;
            color: #B71C1C;
        }

        .instructions {
            background: #E8F5E9;
            border-left: 4px solid var(--primary);
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            font-size: 13px;
        }

        .instructions h3 {
            margin-bottom: 10px;
            color: var(--text);
        }

        .instructions ol {
            margin-left: 20px;
            color: var(--text);
        }

        .instructions li {
            margin-bottom: 6px;
        }

        .success-icon {
            font-size: 48px;
            text-align: center;
            margin: 20px 0;
        }

        .session-info {
            background: var(--light);
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            font-size: 13px;
        }

        .session-info p {
            margin-bottom: 8px;
            color: var(--text);
        }

        .session-info code {
            font-family: 'Courier New', monospace;
            background: white;
            padding: 2px 6px;
            border-radius: 4px;
            color: var(--primary);
            font-weight: 600;
        }

        .error {
            color: var(--danger);
            font-size: 14px;
            margin-top: 10px;
            text-align: center;
        }

        .footer {
            text-align: center;
            padding: 20px;
            color: #65676B;
            font-size: 12px;
            border-top: 1px solid var(--light);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>WhatsApp Bot</h1>
            <p>Reliez votre appareil</p>
        </div>

        <div class="content">
            <!-- Step 1: Phone Input -->
            <div id="step-1" class="step active">
                <h2>Etape 1: Votre numero</h2>
                <form id="phoneForm">
                    <div class="form-group">
                        <label for="phone">Numero international</label>
                        <input 
                            type="tel" 
                            id="phone" 
                            placeholder="22891234567"
                            pattern="[0-9]{8,15}"
                            required
                        >
                        <small style="color: #65676B; display: block; margin-top: 6px;">
                            Format: 8-15 chiffres (sans +)
                        </small>
                    </div>
                    <button type="submit" class="btn btn-primary">Generer Code</button>
                    <div id="phoneError" class="error"></div>
                </form>
            </div>

            <!-- Step 2: Pairing Code -->
            <div id="step-2" class="step">
                <h2>Etape 2: Code de Pairing</h2>
                
                <div class="code-display">
                    <div class="code-label">Code a entrer dans WhatsApp</div>
                    <div class="code-value" id="pairingCode">----</div>
                    <button class="copy-btn" id="copyBtn">Copier</button>
                </div>

                <div class="instructions">
                    <h3>Instructions:</h3>
                    <ol>
                        <li>Ouvrez WhatsApp sur votre telephone</li>
                        <li>Allez dans Parametres</li>
                        <li>Appareils lies</li>
                        <li>Lier un appareil</li>
                        <li>Entrez le code ci-dessus</li>
                    </ol>
                </div>

                <div id="connectionStatus" class="status status-pending">
                    Attente de la connexion...
                </div>

                <button id="cancelBtn" class="btn btn-secondary">Annuler</button>
            </div>

            <!-- Step 3: Success -->
            <div id="step-3" class="step">
                <h2>Succes!</h2>
                <div class="success-icon">+</div>
                <p style="text-align: center; color: #65676B;">
                    Votre bot WhatsApp est maintenant lie
                </p>
                
                <div class="session-info">
                    <p><strong>Session:</strong> <code id="sessionId">---</code></p>
                    <p><strong>Status:</strong> Connecte</p>
                </div>

                <button id="newPairingBtn" class="btn btn-primary">Nouveau Pairing</button>
            </div>
        </div>

        <div class="footer">
            XXXD-BOT v3.0.0
        </div>
    </div>

    <script>
        const API_BASE = '/api/pairing';
        let currentSessionId = null;
        let pollingInterval = null;

        // Form submission
        document.getElementById('phoneForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const phone = document.getElementById('phone').value;
            const errorDiv = document.getElementById('phoneError');
            
            errorDiv.textContent = '';
            
            try {
                const response = await fetch(`${API_BASE}/code`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ phone })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Erreur');
                }

                currentSessionId = data.sessionId;
                document.getElementById('pairingCode').textContent = data.code;
                
                showStep(2);
                pollConnection();

            } catch (error) {
                errorDiv.textContent = error.message;
            }
        });

        // Copy button
        document.getElementById('copyBtn').addEventListener('click', () => {
            const code = document.getElementById('pairingCode').textContent;
            navigator.clipboard.writeText(code).then(() => {
                const btn = document.getElementById('copyBtn');
                btn.textContent = 'Copie!';
                setTimeout(() => btn.textContent = 'Copier', 2000);
            });
        });

        // Cancel button
        document.getElementById('cancelBtn').addEventListener('click', () => {
            if (pollingInterval) clearInterval(pollingInterval);
            showStep(1);
            document.getElementById('phoneForm').reset();
        });

        // New pairing button
        document.getElementById('newPairingBtn').addEventListener('click', () => {
            showStep(1);
            document.getElementById('phoneForm').reset();
            currentSessionId = null;
        });

        function showStep(stepNum) {
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.getElementById(`step-${stepNum}`).classList.add('active');
        }

        async function pollConnection() {
            if (!currentSessionId) return;

            pollingInterval = setInterval(async () => {
                try {
                    const response = await fetch(`${API_BASE}/sessions/${currentSessionId}`);
                    const data = await response.json();

                    if (data.status === 'connected') {
                        clearInterval(pollingInterval);
                        document.getElementById('connectionStatus').textContent = 'Connecte!';
                        document.getElementById('connectionStatus').className = 'status status-connected';
                        document.getElementById('sessionId').textContent = data.sessionId;
                        
                        setTimeout(() => showStep(3), 500);
                    } else if (data.status === 'error') {
                        clearInterval(pollingInterval);
                        document.getElementById('connectionStatus').textContent = 'Erreur de connexion';
                        document.getElementById('connectionStatus').className = 'status status-error';
                    }
                } catch (error) {
                    console.error('Poll error:', error);
                }
            }, 2000);
        }
    </script>
</body>
</html>
