<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pairing WhatsApp - Build by joeslapet</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { min-height: 100vh; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: radial-gradient(circle at top, #25D366 0%, #075E54 55%, #0F4B3F 100%); color: #111; }
        .page { max-width: 480px; margin: 0 auto; padding: 24px; }
        .panel { background: rgba(255,255,255,0.96); border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.18); overflow: hidden; }
        .hero { padding: 32px 30px 20px; text-align: center; background: linear-gradient(135deg, #075E54, #25D366); color: white; }
        .hero h1 { font-size: 28px; margin-bottom: 8px; letter-spacing: 0.04em; }
        .hero p { opacity: 0.9; font-size: 14px; }
        .brand { margin-top: 20px; display: inline-flex; gap: 8px; align-items: center; background: rgba(255,255,255,0.15); padding: 10px 16px; border-radius: 999px; font-size: 13px; }
        .brand strong { color: #fff; }
        .content { padding: 30px 28px 36px; }
        .step { display: none; }
        .step.active { display: block; }
        label { display: block; margin-bottom: 10px; font-weight: 600; color: #0B3A2C; }
        input { width: 100%; border-radius: 14px; border: 1px solid #D8F3E3; padding: 14px 16px; font-size: 16px; background: #F7FFFB; color: #0B3A2C; }
        input:focus { outline: none; box-shadow: 0 0 0 3px rgba(37,211,102,0.18); border-color: #25D366; }
        .button { width: 100%; margin-top: 20px; border: none; border-radius: 14px; padding: 14px 16px; background: linear-gradient(135deg, #25D366, #18A753); color: white; font-size: 16px; cursor: pointer; transition: transform 0.15s ease, opacity 0.15s ease; }
        .button:hover { transform: translateY(-1px); opacity: 0.98; }
        .text-muted { color: #4B5F58; font-size: 14px; line-height: 1.6; margin-top: 16px; }
        .card { background: #F7FFF7; border: 1px solid #D8F3E2; border-radius: 18px; padding: 22px; margin-top: 16px; }
        .code { margin-top: 20px; padding: 20px; background: #111B21; color: #25D366; text-align: center; letter-spacing: 0.18em; font-size: 28px; font-weight: 700; border-radius: 18px; }
        .status { margin-top: 16px; padding: 16px 18px; border-radius: 14px; background: #E9F8EE; color: #0F4B3F; font-weight: 600; }
        .success { background: #DCF8E0; }
        .hint { margin-top: 18px; font-size: 14px; color: #4B5F58; }
    </style>
</head>
<body>
    <div class="page">
        <div class="panel">
            <div class="hero">
                <h1>Pairing WhatsApp</h1>
                <p>Rentre ton numéro, récupère ton code, puis envoie-le au bot.</p>
                <div class="brand"><span>BUILD BY</span><strong>JOESLAPET</strong><span>— HACKER RUSSE</span></div>
            </div>
            <div class="content">
                <div id="step-1" class="step active">
                    <h2>1. Ton numéro</h2>
                    <p class="text-muted">Utilise le format international sans +, par exemple 22891234567.</p>
                    <label for="phoneNumber">Numéro WhatsApp</label>
                    <input id="phoneNumber" type="text" placeholder="22891234567" autocomplete="tel" />
                    <button id="generateButton" class="button">Générer le code</button>
                    <p id="errorMessage" class="hint" style="color: #B00020;"></p>
                </div>
                <div id="step-2" class="step">
                    <h2>2. Code de pairing</h2>
                    <div class="card">
                        <div>Numéro associé :</div>
                        <div id="phoneLabel" style="margin-top: 8px; font-weight: 700;">-</div>
                        <div class="code" id="pairingCode">---- ----</div>
                        <div class="status" id="pairingStatus">En attente du message WhatsApp...</div>
                    </div>
                    <p class="hint">Envoie le code exact au bot WhatsApp depuis ce numéro. Le site vérifie automatiquement la connexion.</p>
                </div>
                <div id="step-3" class="step">
                    <h2>3. Connecté</h2>
                    <div class="card success">
                        <div>✅ Pairing réussi !</div>
                        <div class="hint" style="margin-top: 12px;">Tu peux maintenant utiliser ton bot. Vérifie ta conversation WhatsApp.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        const phoneInput = document.getElementById('phoneNumber');
        const generateButton = document.getElementById('generateButton');
        const errorMessage = document.getElementById('errorMessage');
        const phoneLabel = document.getElementById('phoneLabel');
        const pairingCode = document.getElementById('pairingCode');
        const pairingStatus = document.getElementById('pairingStatus');
        const step1 = document.getElementById('step-1');
        const step2 = document.getElementById('step-2');
        const step3 = document.getElementById('step-3');

        let sessionId = null;
        let pollInterval = null;

        function switchStep(step) {
            [step1, step2, step3].forEach((el, index) => {
                el.classList.toggle('active', index === step - 1);
            });
        }

        function normalizePhone(value) {
            return String(value || '').replace(/[^0-9]/g, '');
        }

        function showError(text) {
            errorMessage.textContent = text;
        }

        function updateStatus(text) {
            pairingStatus.textContent = text;
        }

        async function pollSession() {
            if (!sessionId) return;
            try {
                const response = await fetch(`/api/pairing/sessions/${sessionId}`);
                const data = await response.json();
                if (!response.ok || !data.ok) {
                    updateStatus('Impossible de vérifier la session.');
                    return;
                }
                if (data.status === 'connected') {
                    updateStatus('Pairing confirmé !');
                    switchStep(3);
                    clearInterval(pollInterval);
                    return;
                }
                updateStatus('En attente du message WhatsApp...');
            } catch (err) {
                updateStatus('Erreur de connexion au serveur.');
            }
        }

        generateButton.addEventListener('click', async () => {
            const phoneNumber = normalizePhone(phoneInput.value);
            showError('');

            if (!phoneNumber || phoneNumber.length < 8 || phoneNumber.length > 16) {
                showError('Numéro invalide. Entre ton numéro WhatsApp sans +.');
                return;
            }

            generateButton.disabled = true;
            generateButton.textContent = 'Génération...';

            try {
                const response = await fetch('/api/pairing/code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phoneNumber })
                });
                const data = await response.json();

                if (!response.ok || !data.ok) {
                    showError(data.error || 'Impossible de générer le code.');
                    generateButton.disabled = false;
                    generateButton.textContent = 'Générer le code';
                    return;
                }

                phoneLabel.textContent = data.phoneNumber;
                pairingCode.textContent = data.code;
                sessionId = data.sessionId;
                switchStep(2);
                updateStatus('En attente du message WhatsApp...');

                if (pollInterval) clearInterval(pollInterval);
                pollInterval = setInterval(pollSession, 3000);
                pollSession();
            } catch (err) {
                showError('Erreur serveur. Réessaie.');
            } finally {
                generateButton.disabled = false;
                generateButton.textContent = 'Générer le code';
            }
        });
    </script>
</body>
</html>
