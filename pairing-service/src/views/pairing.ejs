<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pairing QR - Developed by JOE-SLAPET</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #030712;
      --panel: rgba(2, 12, 28, 0.96);
      --panel-soft: rgba(12, 30, 58, 0.88);
      --accent: #39ff14;
      --accent-2: #07f6ff;
      --text: #e9f1ff;
      --muted: #7da3c5;
      --border: rgba(57, 255, 20, 0.18);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: radial-gradient(circle at top, rgba(7, 245, 255, 0.12), transparent 30%),
                  linear-gradient(180deg, #02050d 0%, #081426 46%, #040813 100%);
      color: var(--text);
      overflow-x: hidden;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle at 20% 20%, rgba(57,255,20,0.18), transparent 12%),
                        radial-gradient(circle at 80% 15%, rgba(7,246,255,0.14), transparent 20%);
      pointer-events: none;
    }
    .page {
      position: relative;
      max-width: 1120px;
      margin: 0 auto;
      padding: 30px 18px 60px;
    }
    .nebula {
      position: absolute;
      inset: 0;
      opacity: 0.14;
      background: radial-gradient(circle at 20% 20%, #00ff91 0%, transparent 35%),
                  radial-gradient(circle at 75% 25%, #01d4ff 0%, transparent 28%),
                  radial-gradient(circle at 50% 80%, #ff47d4 0%, transparent 20%);
      mix-blend-mode: screen;
      filter: blur(36px);
      pointer-events: none;
    }
    .panel {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(57,255,20,0.15);
      border-radius: 28px;
      background: var(--panel);
      backdrop-filter: blur(18px);
      box-shadow: 0 30px 80px rgba(0,0,0,0.35);
      padding: 28px;
    }
    .title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .title h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.25rem);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      line-height: 1.05;
      color: #c5ffee;
      text-shadow: 0 0 8px rgba(57,255,20,0.35);
    }
    .badge {
      padding: 10px 16px;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: 0.82rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(0,0,0,0.22);
      animation: pulse 2.5s ease-in-out infinite;
    }
    .hero-text {
      margin-top: 18px;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.8;
      max-width: 760px;
    }
    .grid {
      display: grid;
      gap: 20px;
      margin-top: 32px;
      grid-template-columns: 1.35fr 1fr;
    }
    .card {
      position: relative;
      padding: 24px;
      border-radius: 24px;
      background: rgba(10,20,40,0.9);
      border: 1px solid rgba(255,255,255,0.07);
      overflow: hidden;
    }
    .card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(57,255,20,0.12), transparent 30%);
      pointer-events: none;
    }
    .card h2 {
      margin: 0 0 14px;
      font-size: 1.25rem;
      color: #fff;
      letter-spacing: 0.05em;
    }
    .field {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }
    label { color: #8ab0d3; font-size: 0.92rem; }
    input {
      width: 100%;
      padding: 16px 18px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(10,18,32,0.92);
      color: #f3f9ff;
      font-size: 1rem;
    }
    input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(57,255,20,0.12); }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 16px 18px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, #39ff14 0%, #07f6ff 100%);
      color: #03101f;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 20px 40px rgba(3,16,31,0.18); }
    .output {
      margin-top: 18px;
      padding: 18px;
      border-radius: 18px;
      background: rgba(0,0,0,0.28);
      border: 1px solid rgba(57,255,20,0.12);
      font-family: 'Courier New', Courier, monospace;
      color: #a6f8aa;
      min-height: 138px;
      display: grid;
      gap: 12px;
    }
    .code-box {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
    }
    .chip {
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(7, 245, 255, 0.12);
      border: 1px solid rgba(7, 246, 255, 0.18);
      color: #c6f7ff;
      font-weight: 700;
      letter-spacing: 0.06em;
    }
    .status {
      margin: 0;
      font-size: 0.95rem;
      color: #7de3b3;
    }
    .qr-box {
      margin-top: 18px;
      text-align: center;
    }
    .qr-box img {
      width: min(100%, 260px);
      height: auto;
      border-radius: 18px;
      border: 1px solid rgba(57,255,20,0.18);
      background: rgba(0,0,0,0.45);
    }
    .hint {
      margin-top: 12px;
      color: #8ab0d3;
      font-size: 0.95rem;
      line-height: 1.7;
    }
    .footer {
      margin-top: 24px;
      font-size: 0.85rem;
      color: #5d86ad;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    .glitch {
      color: #c5ffee;
      position: relative;
    }
    .glitch::before,
    .glitch::after {
      content: attr(data-text);
      position: absolute;
      left: 0;
      width: 100%;
      overflow: hidden;
      clip: rect(0, 9999px, 0, 0);
    }
    .glitch::before { animation: glitchTop 2.5s infinite linear alternate-reverse; color: #39ff14; }
    .glitch::after { animation: glitchBottom 3s infinite linear alternate-reverse; color: #07f6ff; }
    @keyframes glitchTop { 0% { clip: rect(0, 9999px, 4px, 0); transform: translate(-2px, -1px); } 100% { clip: rect(12px, 9999px, 16px, 0); transform: translate(2px, 1px); } }
    @keyframes glitchBottom { 0% { clip: rect(50px, 9999px, 64px, 0); transform: translate(2px, 1px); } 100% { clip: rect(85px, 9999px, 89px, 0); transform: translate(-2px, -1px); } }
    @keyframes pulse { 0%,100% { opacity: 0.75; } 50% { opacity: 1; } }
    .matrix {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(circle at 20% 40%, rgba(57,255,20,0.06), transparent 22%),
                        linear-gradient(90deg, rgba(255,255,255,0.04), transparent 60%);
      opacity: 0.12;
      animation: drift 24s linear infinite;
    }
    @keyframes drift { from { transform: translateX(0); } to { transform: translateX(-150px); } }
    @media (max-width: 900px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="nebula"></div>
  <div class="page">
    <div class="panel">
      <div class="matrix"></div>
      <div class="title">
        <div>
          <h1 class="glitch" data-text="WHATSAPP PAIRING">WHATSAPP PAIRING</h1>
          <p class="hero-text">Connecte ton compte au bot par code ou QR. Un style cyber-hacking animé, développé par JOE-SLAPET LE HACKER RUSSE.</p>
        </div>
        <span class="badge">Developed by JOE-SLAPET</span>
      </div>
      <div class="grid">
        <div class="card">
          <h2>1. Génère ton code</h2>
          <div class="field">
            <label for="phoneInput">Numéro WhatsApp</label>
            <input id="phoneInput" placeholder="22891234567" autocomplete="tel" />
          </div>
          <button id="generateBtn" class="btn">Générer le code & QR</button>
          <div class="output" id="outputBox">
            <div class="code-box"><span class="chip">Code:</span><span id="codeValue">---- ----</span></div>
            <p class="status" id="statusText">Prêt à générer. Envoie ensuite le code ou scanne le QR.</p>
          </div>
          <div class="hint">Le QR code ouvre une conversation WhatsApp avec le bot et pré-remplit le message de pairing.</div>
        </div>
        <div class="card">
          <h2>2. QR code de connexion</h2>
          <div class="qr-box">
            <img id="qrImage" src="" alt="QR pairing" />
          </div>
          <p class="hint">Scanne avec ton application WhatsApp ou clique sur le bouton pour ouvrir la conversation.</p>
          <a id="waLink" class="btn" href="#" target="_blank" rel="noopener noreferrer" style="margin-top:18px;">Ouvrir WhatsApp</a>
        </div>
      </div>
      <div class="footer">
        <span>Bot: <strong><%= botNumber %></strong></span>
        <span>Pairing: <strong>QR et code</strong></span>
      </div>
    </div>
  </div>
  <script>
    const phoneInput = document.getElementById('phoneInput');
    const generateBtn = document.getElementById('generateBtn');
    const codeValue = document.getElementById('codeValue');
    const statusText = document.getElementById('statusText');
    const qrImage = document.getElementById('qrImage');
    const waLink = document.getElementById('waLink');

    async function generatePairing() {
      const phone = String(phoneInput.value || '').replace(/[^0-9]/g, '');
      if (!phone || phone.length < 8) {
        statusText.textContent = 'Numéro invalide. Entre ton numéro WhatsApp sans +.';
        return;
      }
      generateBtn.disabled = true;
      generateBtn.textContent = 'Chargement...';
      statusText.textContent = 'Génération du code en cours...';
      try {
        const response = await fetch('/api/pairing/code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phoneNumber: phone })
        });
        const data = await response.json();
        if (!response.ok || !data.ok) {
          statusText.textContent = data.error || 'Erreur serveur.';
          return;
        }
        codeValue.textContent = data.code;
        qrImage.src = data.qrDataUrl;
        waLink.href = data.whatsAppLink;
        waLink.textContent = 'Ouvrir WhatsApp pour envoyer le code';
        statusText.textContent = 'Code créé. Scanne le QR ou ouvre WhatsApp.';
      } catch (err) {
        statusText.textContent = 'Erreur de connexion. Vérifie le service.';
      } finally {
        generateBtn.disabled = false;
        generateBtn.textContent = 'Générer le code & QR';
      }
    }
    generateBtn.addEventListener('click', generatePairing);
  </script>
</body>
</html>
