<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Pairing</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #075E54, #25D366);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            width: 100%;
            max-width: 400px;
            overflow: hidden;
        }
        .header {
            background: linear-gradient(135deg, #075E54, #25D366);
            color: white;
            padding: 30px 20px;
            text-align: center;
        }
        .header h1 { font-size: 24px; margin-bottom: 5px; }
        .header p { font-size: 14px; opacity: 0.9; }
        .content { padding: 30px 20px; }
        .step { display: none; }
        .step.active { display: block; }
        h2 { color: #111B21; font-size: 18px; margin-bottom: 20px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; color: #111B21; font-weight: 500; margin-bottom: 8px; }
        input { 
            width: 100%; 
            padding: 12px; 
            border: 2px solid #E5E5EA; 
            border-radius: 8px; 
            font-size: 16px; 
        }
        input:focus { outline: none; border-color: #25D366; }
        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-primary {
            background: #25D366;
            color: white;
        }
        .btn-primary:hover {
            background: #1FB856;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(37,211,102,0.3);
        }
        .btn-secondary {
            background: #F0F2F5;
            color: #111B21;
            margin-top: 10px;
        }
        .code-display {
            background: #F0F2F5;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            margin: 20px 0;
        }
        .code-label {
            color: #65676B;
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        .code-value {
            font-family: 'Courier New', monospace;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 4px;
            color: #25D366;
        }
        .status {
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            margin: 15px 0;
            font-weight: 500;
        }
        .status-pending {
            background: #FFF3E0;
            color: #E65100;
        }
        .status-connected {
            background: #E8F5E9;
            color: #1B5E20;
        }
        .instructions {
            background: #E8F5E9;
            border-left: 4px solid #25D366;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            font-size: 13px;
        }
        .instructions h3 { margin-bottom: 10px; }
        .instructions ol { margin-left: 20px; }
        .instructions li { margin-bottom: 6px; }
        .error { color: #E74C3C; font-size: 14px; margin-top: 10px; }
        .footer {
            text-align: center;
            padding: 20px;
            color: #65676B;
            font-size: 12px;
            border-top: 1px solid #E5E5EA;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>WhatsApp Bot</h1>
            <p>Reliez votre appareil</p>
        </div>

        <div class="content">
            <div id="step-1" class="step active">
                <h2>Entrez votre numero</h2>
                <form id="phoneForm">
                    <div class="form-group">
                        <label for="phone">Numero international</label>
                        <input 
                            type="tel" 
                            id="phone" 
                            placeholder="22891234567"
                            pattern="[0-9]{8,15}"
                            required
                        >
                        <small style="color: #65676B; display: block; margin-top: 6px;">
                            Format: 8-15 chiffres (sans +)
                        </small>
                    </div>
                    <button type="submit" class="btn btn-primary">Generer Code</button>
                    <div id="phoneError" class="error"></div>
                </form>
            </div>

            <div id="step-2" class="step">
                <h2>Code de Pairing</h2>
                
                <div class="code-display">
                    <div class="code-label">Code a entrer</div>
                    <div class="code-value" id="pairingCode">----</div>
                </div>

                <div class="instructions">
                    <h3>Instructions:</h3>
                    <ol>
                        <li>Ouvrez WhatsApp sur votre telephone</li>
                        <li>Allez dans Parametres</li>
                        <li>Appareils lies</li>
                        <li>Lier un appareil</li>
                        <li>Entrez le code ci-dessus</li>
                    </ol>
                </div>

                <div id="connectionStatus" class="status status-pending">
                    Attente de la connexion...
                </div>

                <button id="cancelBtn" class="btn btn-secondary">Annuler</button>
            </div>

            <div id="step-3" class="step">
                <h2>Succes!</h2>
                <p style="text-align: center; color: #65676B; font-size: 18px;">
                    Session: <code id="sessionId" style="background: #F0F2F5; padding: 5px 10px; border-radius: 4px;">---</code>
                </p>
                <button id="newPairingBtn" class="btn btn-primary">Nouveau Pairing</button>
            </div>
        </div>

        <div class="footer">
            XXXD-BOT v3.0.0
        </div>
    </div>

    <script>
        const API_BASE = '/api/pairing';
        let currentSessionId = null;

        document.getElementById('phoneForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const phone = document.getElementById('phone').value;
            const errorDiv = document.getElementById('phoneError');
            
            errorDiv.textContent = '';
            
            try {
                const response = await fetch(`${API_BASE}/code`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phoneNumber: phone })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Erreur');
                }

                currentSessionId = data.sessionId;
                document.getElementById('pairingCode').textContent = data.code;
                
                showStep(2);

            } catch (error) {
                errorDiv.textContent = error.message;
            }
        });

        document.getElementById('cancelBtn').addEventListener('click', () => {
            showStep(1);
            document.getElementById('phoneForm').reset();
        });

        document.getElementById('newPairingBtn').addEventListener('click', () => {
            showStep(1);
            document.getElementById('phoneForm').reset();
            currentSessionId = null;
        });

        function showStep(stepNum) {
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.getElementById(`step-${stepNum}`).classList.add('active');
        }

        // Simuler la connexion apres 3 secondes
        setTimeout(() => {
            if (currentSessionId && document.getElementById('step-2').classList.contains('active')) {
                document.getElementById('connectionStatus').textContent = 'Connecte!';
                document.getElementById('connectionStatus').className = 'status status-connected';
                document.getElementById('sessionId').textContent = currentSessionId;
                setTimeout(() => showStep(3), 500);
            }
        }, 3000);
    </script>
</body>
</html>
